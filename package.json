{
  "name": "@tencent-classroom/device-check-ui",
  "version": "1.1.0",
  "description": "Tencent Classroom Device Check UI - 腾讯云实时互动-教育版设备检测 UI",
  "type": "module",
  "main": "./dist/device-check-ui.cjs",
  "module": "./dist/device-check-ui.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/device-check-ui.mjs",
      "require": "./dist/device-check-ui.cjs"
    },
    "./style.css": "./dist/style.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "type-check": "vue-tsc --noEmit",
    "mode:opensource": "bash scripts/sync-mode.sh --opensource",
    "mode:local": "bash scripts/sync-mode.sh --local",
    "mode:status": "bash scripts/sync-mode.sh --status"
  },
  "peerDependencies": {
    "element-ui": "^2.15.14",
    "i18next": "^25.8.0",
    "vue": "^2.6.14",
    "@tencent-classroom/device-check-sdk": "^1.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@vitejs/plugin-vue2": "^2.3.1",
    "i18next": "^25.8.0",
    "sass": "^1.60.0",
    "typescript": "~5.3.0",
    "vite": "^4.5.0",
    "vite-plugin-dts": "^3.7.0",
    "vue-tsc": "^2.0.0"
  },
  "dependencies": {
    "i18next-vue": "^1.1.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
